#!/usr/bin/env bash
set -euo pipefail

cd ~/.config/nix
nix flake update
chezmoi add --create flake.lock
trap "git -C ~/.local/share/chezmoi/ checkout -- private_dot_config/nix/create_flake.lock; rm -f ~/.config/nix/flake.lock; chezmoi apply --force ~/.config/nix/flake.lock; exit 1" ERR

cd

s dot run-script home_manager_update

if [[ ${CHEZ_JM_EMACS_ENABLED:-""} == 1 ]]; then
	s emacs reload-config-lite
	s emacs test integration
fi

cd ~/.local/share/chezmoi/private_dot_config/nix/
git add *flake*
git commit -m "flake update" && {
	git pull --no-edit
	git push --recurse-submodules=on-demand
}
