        return True
    if "win32" in name:
        return True
    if "-win" in name:
        return True
    if "win-" in name:
        return True
    if "windows" in name:
        return True
    if name.endswith(".exe"):
        return True
    return False
# for obj in map(lambda x: json.loads(x), sys.stdin.readlines()):
for jsonstr in sys.stdin.readlines():
